{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "run-pytests",
			"type": "shell",
			"command": "pytest -q",
			"group": { "kind": "test", "isDefault": true }
		},
		{
			"label": "install-pytest",
			"type": "shell",
			"command": "pip install pytest",
			"group": "build"
		},
		{
			"label": "run-chat",
			"type": "shell",
			"command": "python chat_cli.py",
			"group": { "kind": "none" }
		},
		{
			"label": "run-companion",
			"type": "shell",
			"command": "python run_companion.py",
			"group": { "kind": "none" }
		},
		{
			"label": "run-web",
			"type": "shell",
			"command": "python run_companion.py --web",
			"group": { "kind": "none" },
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": false,
				"clear": false
			}
		},
		{
			"label": "watch-logs",
			"type": "shell",
			"command": "python tools/watch_logs.py",
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"focus": false,
				"clear": false
			},
			"detail": "Watch web server logs in real-time"
		},
		{
			"label": "start-web-with-logs",
			"dependsOn": ["run-web", "watch-logs"],
			"problemMatcher": [],
			"detail": "Start web server AND watch logs (recommended)"
		}
	]
}