{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "run-pytests",
			"type": "shell",
			"command": "pytest -q",
			"group": { "kind": "test", "isDefault": true }
		},
		{
			"label": "install-pytest",
			"type": "shell",
			"command": "pip install pytest",
			"group": "build"
		},
		{
			"label": "run-chat",
			"type": "shell",
			"command": "python chat_cli.py",
			"group": { "kind": "none" }
		},
		{
			"label": "run-companion",
			"type": "shell",
			"command": "python run_companion.py",
			"group": { "kind": "none" }
		},
		{
			"label": "run-web",
			"type": "shell",
			"command": "python run_companion.py --web",
			"group": { "kind": "none" }
		},
		{
			"label": "run-web-warm",
			"type": "shell",
			"command": "python run_web_with_warmup.py",
			"group": { "kind": "none" },
			"detail": "Warm up model (prompt cache) then start web UI"
		}
	]
}