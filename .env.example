# Companion AI Example Environment Variables
# Copy to .env and fill in your real values (never commit the actual .env)

# Core API Keys
GROQ_API_KEY=your_groq_key_here
# Optional: use a second key for memory tasks else fallback to GROQ_API_KEY
GROQ_MEMORY_API_KEY=

# Web Auth (optional) - if set, required for write operations like fact approval
API_AUTH_TOKEN=

# Azure Speech (optional for TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# Feature Flags (0/1 or true/false)
ENABLE_ENSEMBLE=1
ENABLE_EXPERIMENTAL_MODELS=0
ENABLE_COMPOUND_MODELS=0
ENABLE_FACT_APPROVAL=1
FACT_AUTO_APPROVE=1
VERIFY_FACTS_SECOND_PASS=1

# Ensemble Tuning
ENSEMBLE_MODE=choose_refine
ENSEMBLE_CANDIDATES=3
ENSEMBLE_REFINE_EXPANSION=0.25
ENSEMBLE_REFINE_HARD_CAP=300

# Prompt Caching
ENABLE_PROMPT_CACHING=1

# Logging override (optional) - leave blank for default data/logs
# LOG_DIR_OVERRIDE=
